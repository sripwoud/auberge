[Unit]
Description=Baikal busy feed sync service
After=php{{ baikal_php_version }}-fpm.service

[Service]
Type=oneshot
User={{ baikal_sys_user }}
Group={{ baikal_sys_user }}
WorkingDirectory={{ baikal_install_dir }}
ExecStart={{ baikal_busy_venv }}/bin/python {{ baikal_install_dir }}/baikal-busy-sync.py {{ baikal_data_dir }}/db/db.sqlite {{ baikal_busy_dir }}/busy.ics
StandardOutput=journal
StandardError=journal
ProtectSystem=strict
ReadWritePaths={{ baikal_busy_dir }}
PrivateTmp=true
ProtectHome=true
NoNewPrivileges=true
